  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="560" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="// Código simple para tJavaRow (SIN bucle for)&#xA;int mesNum = Integer.parseInt(input_row.meses);&#xA;int periodValue = input_row.anio * 100 + mesNum;&#xA;&#xA;row2.sk_tiempo = (long) periodValue; &#xA;row2.periodo = periodValue;&#xA;row2.anio = input_row.anio;&#xA;row2.mes = mesNum;&#xA;row2.nombre_mes = new java.text.DateFormatSymbols(new java.util.Locale(&quot;es&quot;,&quot;EC&quot;)).getMonths()[mesNum-1];&#xA;row2.trimestre = (mesNum - 1) / 3 + 1;&#xA;row2.semestre = (mesNum &lt;= 6) ? &quot;S1&quot; : &quot;S2&quot;;&#xA;row2.granularidad = 12;&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_1">
      <column comment="" key="false" length="-1" name="sk_tiempo" nullable="true" pattern="" precision="-1" sourceType="" type="id_Long" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="periodo" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="anio" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="mes" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="nombre_mes" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="trimestre" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="semestre" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
